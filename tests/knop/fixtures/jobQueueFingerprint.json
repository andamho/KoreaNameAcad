{
  "_note": "persistent job queue 구조 fingerprint(0002). 운영 실행 후 이 값과 대조. NOT NULL 은 columns.is_nullable 로만 판단(제약 목록은 PK/UNIQUE/FK/CHECK). 테이블개수만으로 판단 금지.",
  "columnCount": 40,
  "constraints": [
    {
      "tbl": "job_executions",
      "conname": "job_executions_job_id_fkey",
      "contype": "f",
      "def": "FOREIGN KEY (job_id) REFERENCES jobs(id) ON DELETE RESTRICT"
    },
    {
      "tbl": "job_executions",
      "conname": "job_executions_pkey",
      "contype": "p",
      "def": "PRIMARY KEY (id)"
    },
    {
      "tbl": "jobs",
      "conname": "jobs_parent_job_id_fkey",
      "contype": "f",
      "def": "FOREIGN KEY (parent_job_id) REFERENCES jobs(id) ON DELETE RESTRICT"
    },
    {
      "tbl": "jobs",
      "conname": "jobs_pkey",
      "contype": "p",
      "def": "PRIMARY KEY (id)"
    }
  ],
  "indexes": [
    {
      "tablename": "job_executions",
      "indexname": "job_executions_active_uq",
      "indexdef": "CREATE UNIQUE INDEX job_executions_active_uq ON public.job_executions USING btree (job_id) WHERE (status = ANY (ARRAY['claimed'::text, 'running'::text]))"
    },
    {
      "tablename": "job_executions",
      "indexname": "job_executions_job_attempt_key",
      "indexdef": "CREATE UNIQUE INDEX job_executions_job_attempt_key ON public.job_executions USING btree (job_id, attempt_number)"
    },
    {
      "tablename": "job_executions",
      "indexname": "job_executions_pkey",
      "indexdef": "CREATE UNIQUE INDEX job_executions_pkey ON public.job_executions USING btree (id)"
    },
    {
      "tablename": "job_executions",
      "indexname": "job_executions_reaper_idx",
      "indexdef": "CREATE INDEX job_executions_reaper_idx ON public.job_executions USING btree (lease_expires_at) WHERE (status = ANY (ARRAY['claimed'::text, 'running'::text]))"
    },
    {
      "tablename": "jobs",
      "indexname": "jobs_claim_idx",
      "indexdef": "CREATE INDEX jobs_claim_idx ON public.jobs USING btree (priority, available_at, created_at, id) WHERE (status = 'queued'::text)"
    },
    {
      "tablename": "jobs",
      "indexname": "jobs_idempotency_key_key",
      "indexdef": "CREATE UNIQUE INDEX jobs_idempotency_key_key ON public.jobs USING btree (idempotency_key)"
    },
    {
      "tablename": "jobs",
      "indexname": "jobs_parent_idx",
      "indexdef": "CREATE INDEX jobs_parent_idx ON public.jobs USING btree (parent_job_id)"
    },
    {
      "tablename": "jobs",
      "indexname": "jobs_pkey",
      "indexdef": "CREATE UNIQUE INDEX jobs_pkey ON public.jobs USING btree (id)"
    },
    {
      "tablename": "jobs",
      "indexname": "jobs_project_created_idx",
      "indexdef": "CREATE INDEX jobs_project_created_idx ON public.jobs USING btree (project_id, created_at)"
    }
  ],
